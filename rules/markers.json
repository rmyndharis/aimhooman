[
    {
        "id": "marker.corner-cut",
        "version": 2,
        "provider": "generic",
        "category": "ai-marker",
        "confidence": "medium",
        "kind": "code",
        "match": {
            "paths": [
                "**/*"
            ],
            "except": [
                "**/docs/**",
                "**/test/**",
                "**/tests/**",
                "**/fixtures/**",
                "**/__fixtures__/**",
                "**/vendor/**",
                "**/third_party/**",
                "**/node_modules/**",
                "**/dist/**",
                "**/build/**",
                "**/coverage/**",
                "**/generated/**",
                "**/*.generated.*",
                "**/*.min.js",
                "**/*.map",
                "**/*.md"
            ],
            "content": [
                "(?i)\\b(ponytail|caveman|yagni-oneliner):"
            ]
        },
        "actions": {
            "clean": "review",
            "strict": "block",
            "compliance": "review"
        },
        "reason": "AI-tooling corner-cut marker left in committed code.",
        "remediation": [
            "Resolve the shortcut it names, or remove the marker before committing."
        ]
    },
    {
        "id": "marker.ai-authored",
        "version": 1,
        "provider": "generic",
        "category": "ai-marker",
        "confidence": "low",
        "kind": "code",
        "match": {
            "paths": [
                "**/*"
            ],
            "except": [
                "**/docs/**",
                "**/test/**",
                "**/tests/**",
                "**/fixtures/**",
                "**/__fixtures__/**",
                "**/vendor/**",
                "**/third_party/**",
                "**/node_modules/**",
                "**/dist/**",
                "**/build/**",
                "**/coverage/**",
                "**/generated/**",
                "**/*.generated.*",
                "**/*.min.js",
                "**/*.map",
                "**/*.md"
            ],
            "content": [
                "(?i)\\b(ai[- ]?generated|generated by (ai|copilot|claude|chatgpt|codex))\\b"
            ]
        },
        "actions": {
            "clean": "review",
            "strict": "block",
            "compliance": "review"
        },
        "reason": "AI-authored code marker left in committed code.",
        "remediation": [
            "Remove the marker comment if the code is human-owned."
        ]
    }
]
